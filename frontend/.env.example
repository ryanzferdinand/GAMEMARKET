# Local development (default — used when no custom domain is configured)
VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
# Must be SAME client ID as GOOGLE_CLIENT_ID in backend/.env
VITE_BACKEND_URL=http://localhost:5000

# Production (same domain — leave VITE_BACKEND_URL empty)
# VITE_GOOGLE_CLIENT_ID=your_google_client_id_here
# VITE_BACKEND_URL=
#
# Google Console → Authorized JavaScript origins:
#   http://localhost:3000
#   https://schwinn.my.id
