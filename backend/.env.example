PORT=5000
MONGODB_URI=mongodb://localhost:27017/gamemarket
JWT_SECRET=your_super_secret_jwt_key_here
GOOGLE_CLIENT_ID=your_google_client_id_here
# Must match VITE_GOOGLE_CLIENT_ID in frontend/.env (same OAuth Client ID)

# ── Local development (default) ─────────────────────────────────
NODE_ENV=development
FRONTEND_URL=http://localhost:3000

# ── Production / custom domain ──────────────────────────────────
# NODE_ENV=production
# FRONTEND_URL=https://schwinn.my.id
# ALLOWED_ORIGINS=https://schwinn.my.id,https://www.schwinn.my.id
#
# Google Cloud Console → OAuth Client → Authorized JavaScript origins:
#   http://localhost:3000
#   https://schwinn.my.id
# (BUKAN Redirect URI — app pakai Google Identity Services / ID token)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# ── Marketplace / Wallet ────────────────────────────────────────
MARKETPLACE_FEE_PERCENT=5
WITHDRAW_MIN=50000
AUTO_CONFIRM_HOURS=24
MODERATOR_REASSIGN_MINUTES=15
PAYMENT_WEBHOOK_SECRET=your_webhook_secret_here

# ── Email Verification ──────────────────────────────────────────
# EMAIL_VERIFICATION_REQUIRED=true  → user HARUS verif email sebelum bisa login
# EMAIL_VERIFICATION_REQUIRED=false → verif email opsional (default)
EMAIL_VERIFICATION_REQUIRED=false

# Provider: zoho | brevo  (kosongkan = dev mode, log ke console saja)
EMAIL_PROVIDER=zoho
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=GameMarket

# ── Zoho Mail SMTP ──────────────────────────────────────────────
# 1. Buat akun di https://zoho.com/mail
# 2. Aktifkan IMAP/SMTP di Settings → Mail Accounts → IMAP Access
# 3. Buat App Password di Settings → Security → App Password
# SMTP Host: smtp.zoho.com  Port: 465 (SSL)
ZOHO_USER=akun@yourdomain.com
ZOHO_PASS=your_zoho_app_password

# ── Brevo (Sendinblue) SMTP ─────────────────────────────────────
# 1. Daftar di https://app.brevo.com
# 2. SMTP & API → Generate SMTP Key
# 3. SMTP Host: smtp-relay.brevo.com  Port: 587 (STARTTLS)
# BREVO_SMTP_USER=your_brevo_login_email
# BREVO_SMTP_PASS=your_brevo_smtp_key

# ── Dispute Moderation Fee ──────────────────────────────────────
# Jika durasi moderator di dalam dispute chat melebihi DISPUTE_FREE_MINUTES,
# akan dikenakan biaya tambahan sebesar DISPUTE_FEE_PERCENT% dari order.amount.
# Biaya ini masuk ke wallet moderator/admin yang menangani.
# Fee platform (MARKETPLACE_FEE_PERCENT%) tetap berjalan normal.
#
# DISPUTE_FREE_MINUTES  : Berapa menit gratis sebelum biaya mulai dihitung (default: 30)
# DISPUTE_FEE_PERCENT   : Persen biaya dari order.amount jika melebihi batas gratis (default: 2)
# DISPUTE_FEE_PAYER     : Siapa yang menanggung biaya:
#                           loser  = pihak yang kalah dispute (default)
#                           buyer  = selalu pembeli
#                           seller = selalu penjual
#                           split  = dibagi 50/50
DISPUTE_FREE_MINUTES=30
DISPUTE_FEE_PERCENT=2
DISPUTE_FEE_PAYER=loser

# ── Midtrans (optional — leave empty to use simulate mode) ─────
# Get keys from https://dashboard.midtrans.com/settings/access_keys
# Sandbox Server Key starts with SB-Mid-server-
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
# Notification URL in Midtrans dashboard:
#   https://yourdomain.com/api/webhooks/midtrans
# ALLOW_PAYMENT_SIMULATE=true
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Falls back to JWT_SECRET if unset. New messages are encrypted in MongoDB.
CHAT_ENCRYPTION_KEY=your_64_char_hex_key_here
